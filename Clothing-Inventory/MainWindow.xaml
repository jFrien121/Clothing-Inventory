<Window x:Class="Clothing_Inventory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Clothing_Inventory" 
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Top-Inventory-1.0" Height="450" Width="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:ColorZone 
            Grid.Row="0"
            Mode="PrimaryMid"
            Padding="25">
            <StackPanel Orientation="Horizontal" Height="50" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Hanger" VerticalAlignment="Center" Width="27" Height="30"/>
                <TextBlock
                    Height="32"
                    Margin="16,0,0,0"
                    Text="Clothing Inventory"
                    FontSize="19"/>
            </StackPanel>
        </materialDesign:ColorZone>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width=".30*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="0.2*"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                    Loaded="DataGrid_Loaded"
                    CanUserAddRows="False"
                    Style="{StaticResource MaterialDesignDataGrid}"
                    IsReadOnly="True"
                    AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Last Worn" Binding="{Binding lastWorn}"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding description}"/>
                        <DataGridTextColumn Header="Colour(s)" Binding="{Binding mainColour}"/>
                        <DataGridTextColumn Header="Shirt Type" Binding="{Binding type}"/>
                    </DataGrid.Columns>

                    <!--<Style TargetType="DataGridColumnHeader"
                        BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>

                    <Style TargetType="DataGridCell"
                        BasedOn="{StaticResource MaterialDesignDataGridCell}">
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>-->
                </DataGrid>

            </Grid>
        </Grid>
    </Grid>
</Window>
