<Window x:Class="Clothing_Inventory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Clothing_Inventory" 
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:ui="clr-namespace:Clothing_Inventory.ui"
        mc:Ignorable="d"
        Title="Top-Inventory-1.0" Height="450" Width="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:ColorZone 
            Grid.Row="0"
            Mode="PrimaryMid"
            Height="65"
            Padding="25,0,0,0">
            <StackPanel Orientation="Horizontal" Height="50" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Hanger" VerticalAlignment="Center" Width="27" Height="30"/>
                <TextBlock
                    Height="31"
                    Margin="16,0,0,0"
                    Text="Clothing Inventory"
                    FontSize="22"/>
            </StackPanel>
        </materialDesign:ColorZone>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width=".30*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="0.2*"/>
                </Grid.RowDefinitions>

                <DataGrid Name="ClothesGrid"
                    Grid.Row="0"
                    Loaded="DataGrid_Loaded"
                    CanUserAddRows="False"
                    Style="{StaticResource MaterialDesignDataGrid}"
                    IsReadOnly="True"
                    Margin="10"
                    AutoGenerateColumns="False"
                    Padding="10"
                    SelectionChanged="ClothesGrid_SelectionChanged">

                    <!--<Style TargetType="DataGridColumnHeader"
                        BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>

                    <Style TargetType="DataGridCell"
                        BasedOn="{StaticResource MaterialDesignDataGridCell}">
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>-->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Last Worn" Binding="{Binding lastWorn}" HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding description}" HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"/>
                        <DataGridTextColumn Header="Colour(s)" Binding="{Binding mainColour}" HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"/>
                        <DataGridTextColumn Header="Shirt Type" Binding="{Binding type}" HeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="205"/>
                        <ColumnDefinition Width="195"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="105"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Name="FilterType"
                        Margin="15"
                        Width="175"
                        Padding="2"
                        Height="25"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        materialDesign:HintAssist.Hint="Filter By"
                        Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                            <ComboBoxItem Content="Shirt Type" />
                            <ComboBoxItem Content="Colour" />
                            <ComboBoxItem Content="Description" />
                    </ComboBox>

                    <TextBox Name="FilterBy"
                      Grid.Column="1"
                      Padding="2"
                      Margin="10,15,10,5"
                      VerticalAlignment="Top"
                      HorizontalAlignment="Left"
                      Width="175"
                      materialDesign:HintAssist.Hint="Filter"
                      Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                    <Button Grid.Column="2" Name="SearchButton"
                        Width="85"
                        Content="SEARCH"
                        Margin="10,15,0,0"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Left"
                        IsEnabled="{Binding DataContext.ControlsEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        ToolTip="Resource name: MaterialDesignRaisedButton" />

                    <Button Grid.Column="3" Name="ResetButton"
                        Width="85"
                        Content="RESET"
                        Margin="0,15,10,0"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        IsEnabled="{Binding DataContext.ControlsEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        ToolTip="Resource name: MaterialDesignRaisedButton" />
                </Grid>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height=".2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Name="EditButton"
                        Width="75"
                        Content="EDIT"
                        IsEnabled="{Binding DataContext.ControlsEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        ToolTip="Resource name: MaterialDesignRaisedButton" 
                         Click="EditButton_Click"/>

                    <Button Grid.Column="1" Name="AddButton"
                        Width="75"
                        Content="ADD"
                        IsEnabled="{Binding DataContext.ControlsEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        ToolTip="Resource name: MaterialDesignRaisedButton" />
                </Grid>

                <ui:EditItem x:Name="EditItemUI"
                    Grid.Row="1" />
            </Grid>
        </Grid>
    </Grid>
</Window>
