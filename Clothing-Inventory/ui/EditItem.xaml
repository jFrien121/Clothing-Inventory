<UserControl x:Class="Clothing_Inventory.ui.EditItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Clothing_Inventory.ui"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="318" d:DesignWidth="185">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBox
          Grid.Row="0"
          Padding="2"
          Margin="10,5,10,5"
          VerticalAlignment="Center"
          materialDesign:HintAssist.Hint="Colour"
          Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

        <TextBox
          Grid.Row="1"
          Padding="2"
          Margin="10,5,10,5"
          VerticalAlignment="Center"
          materialDesign:HintAssist.Hint="Description"
          Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

        <TextBox
          Grid.Row="2"
          Padding="2"
          Margin="10,5,10,5"
          VerticalAlignment="Center"
          materialDesign:HintAssist.Hint="Top Type"
          Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

        <DatePicker Grid.Row="3"
                    Margin="10,3,10,3"
                    Padding="2,10,0,0"
                    Height="40"
                    SelectedDate="05/10/2026"
                    materialDesign:HintAssist.Hint="Last Worn"
                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />
    </Grid>
</UserControl>
